#!/bin/bash

# MpiTouchBridge — SetupHelper install/uninstall script
# QDtech MPI5001/MPI5006 touch bridge for Victron Cerbo GX (Venus OS)
#
# Installs a runit service that:
#   - locates the touch device dynamically by USB VID:PID
#   - grabs the event node so Qt6 never sees broken coordinates
#   - forwards correct coordinates via a uinput virtual touchscreen
#   - restarts automatically on USB disconnect/reconnect or crash

packageName="MpiTouchBridge"

source "/data/SetupHelper/HelperResources/IncludeHelpers"

if [ $scriptAction == 'NONE' ]; then
    standardActionPrompt
fi

case $scriptAction in

    INSTALL)
        logMessage "installing $packageName touch bridge service"

        # Remove the legacy rc.local entry if present
        if [ -f /data/rc.local ] && grep -q "touch-bridge.py" /data/rc.local; then
            logMessage "removing legacy rc.local entry"
            sed -i '/touch-bridge\.py/d' /data/rc.local
        fi

        # Kill any instance started by rc.local or manually
        pkill -f "touch-bridge.py" 2>/dev/null || true

        # Inject "Touch screen off" option into the display settings page
        logMessage "patching PageSettingsDisplay.qml"
        python3 /data/victron-mpi5006-touch/patch-qml.py patch

        # Restart the GUI so the new menu item is visible immediately
        svc -t /service/gui 2>/dev/null || true
        ;;

    UNINSTALL)
        logMessage "uninstalling $packageName touch bridge service"

        # Restore original QML file
        logMessage "restoring PageSettingsDisplay.qml"
        python3 /data/victron-mpi5006-touch/patch-qml.py unpatch

        # Restart the GUI
        svc -t /service/gui 2>/dev/null || true
        ;;

esac

endScript INSTALL_SERVICES ADD_DBUS_SETTINGS
